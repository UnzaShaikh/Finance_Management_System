{
  "name": "finance-tracker-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "build": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "build-backend": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "build-frontend": "cd frontend && npm install --include=dev && npm run build"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^2.3.2",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.6.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.2",
    "pg": "^8.20.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}