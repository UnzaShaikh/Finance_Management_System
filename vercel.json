{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/prisma/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/dist/$1"
    }
  ],
  "cleanUrls": true
}
